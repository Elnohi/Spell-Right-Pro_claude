# ─── Static asset pass-throughs (must be BEFORE catch-all) ──────────
# Prevents the SPA catch-all from intercepting JSON/JS/data fetches.
# Netlify serves real files first, but the force=true in netlify.toml
# catch-all would override without these explicit rules.
/data/*               /data/:splat         200
/js/*                 /js/:splat           200
/css/*                /css/:splat          200
/assets/*             /assets/:splat       200
/.well-known/*        /.well-known/:splat  200

